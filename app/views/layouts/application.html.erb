<!DOCTYPE html>
<html>
  <head>
    <title>ShrineRailsExample</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Third-party CSS loaded directly from a CDN (no build step) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uppy@5.2.4/dist/uppy.min.css">

    <!-- Application CSS served by Propshaft -->
    <%= stylesheet_link_tag "application" %>

    <!-- Application JavaScript loaded via import maps -->
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
